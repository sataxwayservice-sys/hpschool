# School Management System - Apache Configuration
# Prevent directory browsing
Options -Indexes
DirectoryIndex index.php index.html

# Enable URL Rewriting
RewriteEngine On

# Prevent direct access to sensitive files
<FilesMatch "\.(sql|env|ini|log|bak|sqlite|sqlite3)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Block root config files and common local debug scripts
<FilesMatch "^(config\.php|database\.php|database\.live\.php|firebase_config\.php)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Block installation, migration, test, and diagnostic utilities in production
<FilesMatch "^(setup(?:_.*)?|create_admin|reset_password|fix_.*|check_.*|test_.*|debug_.*|diagnose_database|full_diagnostic|list_receipts|manage_assigned_fees|update_student_batches|add_.*)\.php$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>
